# Copy to .env for local dev, or set these in your host's secret manager.
# To share one backend across multiple deployments, use the same DATABASE_URL and REDIS_URL everywhere.

NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Optional paths (used mainly on Render when a disk is mounted)
DATA_DIR=./data
UPLOADS_DIR=./data/avatars
