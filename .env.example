# Copy to .env for local dev or a Linux PC service.
# To share one backend across multiple deployments, use the same DATABASE_URL and REDIS_URL everywhere.

NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
DATABASE_URL=postgres://nexus:nexus-local-password@127.0.0.1:5432/nexus

# Optional for one Linux PC. Add Redis if you run multiple app processes or want shared call state.
REDIS_URL=redis://127.0.0.1:6379
REQUIRE_REDIS=false

# Local PostgreSQL usually does not use SSL. Managed/cloud PostgreSQL often does.
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Set COOKIE_SECURE=true only when users access the app over HTTPS.
# If Nginx/Caddy terminates HTTPS in front of Node, also set TRUST_PROXY=1.
COOKIE_SECURE=false
TRUST_PROXY=

# Optional paths (used mainly on Render when a disk is mounted)
DATA_DIR=./data
UPLOADS_DIR=./data/avatars
