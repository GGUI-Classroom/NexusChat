# Copy to .env and point DATABASE_URL at your Supabase PostgreSQL connection string.
# Never commit real Supabase passwords or database URLs.

NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me-to-a-random-secret-with-at-least-32-characters
# Only for disposable local experiments. Never set this in production.
ALLOW_INSECURE_DEV_SECRET=false

# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# Use the URI string and replace [YOUR-PASSWORD] with your database password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=5

# Optional. Leave blank for one Node process; realtime works inside that process.
REDIS_URL=
REQUIRE_REDIS=false

# Set COOKIE_SECURE=true only when users access the app over HTTPS.
COOKIE_SECURE=false
TRUST_PROXY=
COOKIE_SAME_SITE=lax
# HTTPS deployments that must keep sessions inside cross-site iframes can set
# this to true. It forces COOKIE_SAME_SITE=none and requires COOKIE_SECURE=true.
ALLOW_CROSS_SITE_IFRAMES=false
# Never enable file:// clients for the public deployment. The offline copy can
# still open locally, but it must not receive your live authenticated session.
ALLOW_FILE_CLIENTS=false
# Production: set this to the exact HTTPS public domain users open in a browser.
# Example: https://chat.example.com
PUBLIC_APP_ORIGIN=
# Optional explicit allow-list for a separately hosted trusted browser client.
STATIC_CLIENT_ORIGINS=

# Must exactly match NEXUS_LINK_SHARED_SECRET on the separate Nexus LINK service.
# Use at least 32 random characters if configured.
NEXUS_LINK_SHARED_SECRET=
NEXUS_LINK_URL=https://YOUR-NEXUS-LINK.onrender.com
# Must exactly match LINK_STATE_SECRET on the separate Nexus LINK service.
NEXUS_LINK_STATE_SECRET=

# Keep these only in Render environment variables, never in browser files or Git.
# Comma-separated user IDs that should have core admin authority.
CORE_ADMIN_IDS=
# Optional comma-separated user IDs that non-core admins cannot remove.
NON_REMOVABLE_ADMIN_IDS=
ADMIN_QR_CODE=
# Production admin/limited codes must be at least 16 random characters.
LIMITED_ADMIN_NFC_CODE=
LIMITED_ADMIN_ACCESS_CODE=
