# Copy to .env and point DATABASE_URL at your Supabase PostgreSQL connection string.
# Never commit real Supabase passwords or database URLs.

NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# Use the URI string and replace [YOUR-PASSWORD] with your database password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=5

# Optional. Leave blank for one Node process; realtime works inside that process.
REDIS_URL=
REQUIRE_REDIS=false

# Set COOKIE_SECURE=true only when users access the app over HTTPS.
COOKIE_SECURE=false
TRUST_PROXY=

# Must exactly match NEXUS_LINK_SHARED_SECRET on the separate Nexus LINK service.
NEXUS_LINK_SHARED_SECRET=
